# LLM Configuration
LLM_BASE_URL=http://localhost:8081/v1
LLM_API_KEY=00000000
LLM_MODEL=qwen-local
LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=3
LLM_TIMEOUT=60

# Graph Configuration
GRAPH_RECURSION_LIMIT=20
GRAPH_CHECKPOINT_INTERVAL=5

# Review Configuration
REVIEW_MIN_APPROVAL_SCORE=0.7
REVIEW_MAX_REVISION_CYCLES=3

# Output Configuration
OUTPUT_FORMAT=docx
OUTPUT_DIR=./output